Screen {
    align-horizontal: center;
    align-vertical: top;
    hatch: right $background-lighten-1;
}

DataTable {
    width: auto;
    background: $background;
}


.hidden {
    display: none;
}

*:focus {
    background: $background;
}

Tooltip {
    offset-x: 2;
    offset-y: 1;
    max-width: 72;
}
